# Vercel Postgres (Neon) - được Vercel inject tự động khi link với storage
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=
POSTGRES_USER=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=

# Vercel Blob - tự inject khi link
BLOB_READ_WRITE_TOKEN=

# Tự sinh: openssl rand -base64 32
JWT_SECRET=

# 'production' khi deploy, để trống khi vercel dev
NODE_ENV=
